#!/usr/bin/env bash
#
# tools/ai — AI tool launcher hub
# Ultra-short subcommands for phone keyboards
#
# Usage: ai [command] [args...]
#   ai          Dashboard (tasks + tmux)
#   ai c        Claude Code (full permissions)
#   ai x        Codex CLI
#   ai g        Gemini CLI
#   ai q        Qwen/Ollama (local)
#   ai o        OpenCode (model router)
#   ai ad       Aider
#   ai ?        Help card
#
set -euo pipefail

_script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
AI_TOOLS_DIR="$(dirname "$_script_dir")"

# Colors (auto-disabled on pipe or NO_COLOR)
if [[ -t 1 ]] && [[ -z "${NO_COLOR:-}" ]]; then
  R=$'\e[31m' G=$'\e[32m' Y=$'\e[33m' B=$'\e[34m'
  M=$'\e[35m' C=$'\e[36m' W=$'\e[1m'  D=$'\e[2m' N=$'\e[0m'
else
  R='' G='' Y='' B='' M='' C='' W='' D='' N=''
fi

_cols() { echo "${COLUMNS:-$(tput cols 2>/dev/null || echo 80)}"; }
trunc() { local s="$1" max="${2:-$(_cols)}"; (( ${#s} > max )) && echo "${s:0:$((max-2))}.." || echo "$s"; }
hdr() { echo "${W}--- $1 ---${N}"; }
die() { echo "${R}err:${N} $*" >&2; exit 1; }
info() { echo "${G}>${N} $*"; }
need_tmux() { [[ -n "${TMUX:-}" ]] || die "not in tmux"; }

# ---- STATUS ----
cmd_status() {
  local w=$(_cols)
  local open_n wip_n
  open_n=$(bd count --status=open 2>/dev/null || echo 0)
  wip_n=$(bd count --status=in_progress 2>/dev/null || echo 0)
  hdr "Tasks (${open_n} open, ${wip_n} wip)"
  {
    bd list --status=in_progress 2>/dev/null || true
    bd list --status=open 2>/dev/null || true
  } | head -8 | while IFS= read -r line; do trunc " $line" "$w"; done
  [[ $((open_n + wip_n)) -eq 0 ]] && echo " ${D}(none)${N}"
  if [[ -n "${TMUX:-}" ]]; then
    hdr "Tmux"
    tmux list-windows -F ' #{window_index}:#{window_name}#{?window_active,*, }' 2>/dev/null || true
  fi
}

# ---- TASK SHORTCUTS ----
cmd_ready() { bd ready 2>/dev/null || echo "No ready tasks"; }
cmd_take()  {
  local id="${1:-}"; [[ -z "$id" ]] && die "usage: ai t ID"
  [[ "$id" == *-* ]] || id="AI-Tools-$id"
  bd update "$id" --status=in_progress && info "took $id"
}
cmd_done()  {
  local id="${1:-}"; [[ -z "$id" ]] && die "usage: ai d ID"
  [[ "$id" == *-* ]] || id="AI-Tools-$id"
  local reason="${2:-}"
  [[ -n "$reason" ]] && bd close "$id" --reason="$reason" || bd close "$id"
  info "closed $id"
}
cmd_new()   { local title="$*"; [[ -z "$title" ]] && die "usage: ai n <title>"; bd create --title="$title" --type=task --priority=2; }
cmd_info()  {
  local id="${1:-}"; [[ -z "$id" ]] && die "usage: ai i ID"
  [[ "$id" == *-* ]] || id="AI-Tools-$id"
  bd show "$id"
}

# ---- TMUX HELPERS ----
cmd_windows() {
  need_tmux
  local target="${1:-}"
  if [[ -z "$target" ]]; then tmux list-windows -F ' #{window_index}:#{window_name}#{?window_active,*, }'
  else tmux select-window -t "$target" && info "switched to $target"; fi
}
cmd_peek() {
  need_tmux
  local target="${1:-0}" lines="${2:-15}"
  echo "${D}--- pane $target (last $lines lines) ---${N}"
  tmux capture-pane -t "$target" -p -S "-$lines"
}
cmd_kill() {
  need_tmux
  local target="${1:-}"; [[ -z "$target" ]] && die "usage: ai k N"
  tmux send-keys -t "$target" C-c && info "sent Ctrl-C to pane $target"
}

# ---- SYNC ----
cmd_flush() { "$AI_TOOLS_DIR/tools/sync" && info "synced"; }

# ---- AI LAUNCHERS ----
cmd_launch() {
  local letter="$1"; shift
  local bin flags
  case "$letter" in
    c)  bin="claude";    flags="--dangerously-skip-permissions" ;;
    x)  bin="codex";     flags="--full-auto" ;;
    g)  bin="gemini";    flags="-y" ;;
    a)  bin="amp";       flags="--trust-tools" ;;
    o)  bin="opencode";  flags="" ;;
    q)  bin="ollama run qwen2.5:3b"; flags="" ;;
    ad) bin="aider";     flags="" ;;
    *) die "unknown tool: $letter" ;;
  esac
  command -v "${bin%% *}" &>/dev/null || die "${bin} not found in PATH"
  info "launching $bin${flags:+ $flags}"
  # shellcheck disable=SC2086
  $bin $flags "$@"
}

# ---- HELP ----
cmd_help() { cat <<'EOF'
ai — AI Tool Hub

STATUS
  ai          Dashboard (tasks + tmux)

LAUNCH AI
  ai c [args]  Claude (--dangerously-skip-permissions)
  ai x [args]  Codex (--full-auto)
  ai g [args]  Gemini (-y yolo mode)
  ai a [args]  Amp (--trust-tools)
  ai o [args]  OpenCode (model router)
  ai q [args]  Qwen/Ollama (local)
  ai ad [args] Aider

TASKS (beads)
  ai r         Ready tasks
  ai t ID      Take task → in_progress
  ai d ID      Done → close
  ai n words   New task
  ai i ID      Show task details

TMUX
  ai w         List windows
  ai w N       Switch to window N
  ai p N       Peek pane N
  ai k N       Send Ctrl-C to pane N

SYNC
  ai f         Sync session (bd sync + memory)

  ai ?         This help
EOF
}

# ---- DISPATCH ----
cmd="${1:-s}"
shift || true

case "$cmd" in
  s|status)        cmd_status ;;
  c|x|g|a|o|q|ad) cmd_launch "$cmd" "$@" ;;
  r|ready)         cmd_ready ;;
  t|take)          cmd_take "$@" ;;
  d|done)          cmd_done "$@" ;;
  n|new)           cmd_new "$@" ;;
  i|info)          cmd_info "$@" ;;
  w|windows)       cmd_windows "$@" ;;
  p|peek)          cmd_peek "$@" ;;
  k|kill)          cmd_kill "$@" ;;
  f|flush|sync)    cmd_flush ;;
  \?|help|--help|-h) cmd_help ;;
  *) die "unknown: $cmd (try ai ?)" ;;
esac
