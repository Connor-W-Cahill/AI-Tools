def cmd_issues(project_key=None):
    cfg = load_config()
    token, tokens = get_token(cfg)
    cloud_id = get_cloud_id(token, tokens)

    if project_key:
        jql = urllib.parse.quote(f"project = {project_key.upper()} ORDER BY updated DESC")
    else:
        jql = urllib.parse.quote("assignee = currentUser() ORDER BY updated DESC")

    data = jira_get(f"/search/jql?jql={jql}&maxResults=30&fields=summary,status,assignee,priority,project",
                    cfg, token, cloud_id)
    issues = data.get("issues", []) if data else []

    if not issues:
        print("No issues found.")
        return

    print(f"\n{W}{'Key':<14} {'Priority':<10} {'Status':<20} Summary{N}")
    print("─" * 80)
    for i in issues:
        key      = i.get("key", "")
        f        = i.get("fields", {})
        summary  = (f.get("summary") or "")[:42]
        status   = (f.get("status") or {}).get("name", "")[:18]
        priority = (f.get("priority") or {}).get("name", "")[:8]
        pcolor   = R if priority == "Highest" else Y if priority in ("High","Medium") else G
        print(f"{C}{key:<14}{N} {pcolor}{priority:<10}{N} {status:<20} {summary}")
    print()


def cmd_view(key):
    cfg = load_config()
    token, tokens = get_token(cfg)
    cloud_id = get_cloud_id(token, tokens)

    issue = jira_get(f"/issue/{key}?fields=summary,description,status,assignee,priority,comment",
                     cfg, token, cloud_id)
    if not issue:
        die(f"Issue {key} not found.")

    f = issue["fields"]
    print(f"\n{W}{key}{N}: {f.get('summary','')}")
    print(f"{W}Status:{N}   {(f.get('status') or {}).get('name','')}")
    print(f"{W}Priority:{N} {(f.get('priority') or {}).get('name','')}")
    assignee = (f.get("assignee") or {}).get("displayName", "Unassigned")
    print(f"{W}Assignee:{N} {assignee}")

    # Description (ADF text extraction)
    desc = f.get("description")
    if desc and isinstance(desc, dict):
        texts = []
        def extract(node):
            if isinstance(node, dict):
                if node.get("type") == "text":
                    texts.append(node.get("text",""))
                for child in node.get("content", []):
                    extract(child)
        extract(desc)
        print(f"\n{W}Description:{N}")
        print(" ".join(texts)[:500])

    # Recent comments
    comments = (f.get("comment") or {}).get("comments", [])
    if comments:
        print(f"\n{W}Comments ({len(comments)}):{N}")
        for c in comments[-3:]:
            author = (c.get("author") or {}).get("displayName","?")
            texts = []
            def extract_c(node):
                if isinstance(node, dict):
                    if node.get("type") == "text":
                        texts.append(node.get("text",""))
                    for child in node.get("content",[]):
                        extract_c(child)
            extract_c(c.get("body",{}))
            print(f"  {Y}{author}:{N} {' '.join(texts)[:120]}")
    print()


