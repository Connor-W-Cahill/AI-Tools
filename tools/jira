def load_config():
    if not CONFIG_FILE.exists():
        die(f"Config not found at {CONFIG_FILE}\nRun setup or check credentials.")
    with open(CONFIG_FILE) as f:
        return json.load(f)


def load_tokens():
    if not TOKEN_FILE.exists():
        return None
    with open(TOKEN_FILE) as f:
        return json.load(f)


def save_tokens(data):
    TOKEN_FILE.parent.mkdir(parents=True, exist_ok=True)
    with open(TOKEN_FILE, "w") as f:
        json.dump(data, f, indent=2)
    TOKEN_FILE.chmod(0o600)


def die(msg):
    print(f"{R}Error:{N} {msg}", file=sys.stderr)
    sys.exit(1)


def http_post(url, data, headers=None):
    body = json.dumps(data).encode()
    req = urllib.request.Request(url, data=body,
                                  headers={"Content-Type": "application/json", **(headers or {})})
    try:
        with urllib.request.urlopen(req) as r:
            return json.loads(r.read())
    except urllib.error.HTTPError as e:
        die(f"HTTP {e.code} on POST {url}: {e.read().decode()}")


def http_get(url, token):
    req = urllib.request.Request(url, headers={"Authorization": f"Bearer {token}",
                                               "Accept": "application/json"})
    try:
        with urllib.request.urlopen(req) as r:
            return json.loads(r.read())
    except urllib.error.HTTPError as e:
        if e.code == 401:
            return None  # signal token refresh needed
        die(f"HTTP {e.code} on GET {url}: {e.read().decode()}")


def refresh_access_token(cfg, tokens):
    data = {
        "grant_type": "refresh_token",
        "client_id": cfg["client_id"],
        "client_secret": cfg["client_secret"],
        "refresh_token": tokens["refresh_token"],
    }
    result = http_post(TOKEN_URL, data)
    tokens.update(result)
    save_tokens(tokens)
    return tokens


def get_token(cfg):
    """Get a valid access token, refreshing if needed."""
    tokens = load_tokens()
    if not tokens:
        die("Not authenticated. Run:  jira auth")

    # Try existing token
    result = http_get(RESOURCES_URL, tokens["access_token"])
    if result is not None:
        return tokens["access_token"], tokens

    # Refresh
    print(f"{Y}Token expired, refreshing...{N}")
    if "refresh_token" not in tokens:
        die("No refresh token. Run:  jira auth")
    tokens = refresh_access_token(cfg, tokens)
    return tokens["access_token"], tokens


def get_cloud_id(token, tokens):
    """Get the Atlassian cloud ID (needed for API calls)."""
    resources = http_get(RESOURCES_URL, token)
    if not resources:
        die("Could not fetch accessible resources.")
    # Find statlerits
    for r in resources:
        if "statlerits" in r.get("url", ""):
            return r["id"]
    # Fallback to first
    if resources:
        return resources[0]["id"]
    die("No Jira Cloud resources found for this account.")


def jira_get(path, cfg, token, cloud_id):
    url = f"https://api.atlassian.com/ex/jira/{cloud_id}/rest/api/3{path}"
    return http_get(url, token)


def jira_post(path, body, cfg, token, cloud_id):
    url = f"https://api.atlassian.com/ex/jira/{cloud_id}/rest/api/3{path}"
    return http_post(url, body, headers={"Authorization": f"Bearer {token}"})


