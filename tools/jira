    "sync":       (cmd_sync,       0),
    "start":      (cmd_start,      1),
    "done":       (cmd_done,       1),
}

if __name__ == "__main__":
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help", "help"):
        usage()
        sys.exit(0)

    cmd = args[0]
    if cmd not in COMMANDS:
        die(f"Unknown command: {cmd}\nRun 'jira help' for usage.")

    fn, nargs = COMMANDS[cmd]
    rest = args[1:]

    if nargs == 0:
        fn()
    elif nargs == -1:
        fn(*rest) if rest else fn()
    else:
        if len(rest) < nargs:
            die(f"'{cmd}' requires {nargs} argument(s).")
        fn(*rest[:nargs])
