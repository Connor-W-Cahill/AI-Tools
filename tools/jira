#!/usr/bin/env python3
"""
tools/jira — Jira CLI for AI-Tools workflow
OAuth 2.0 (3LO) with statlerits.atlassian.net

Usage:
  jira auth                    Run OAuth flow (required first time)
  jira boards                  List accessible projects
  jira issues [PROJECT]        List issues (all yours, or by project key)
  jira view <key>              View a ticket (e.g. PROJ-123)
  jira create [summary]        Create ticket (auto-routes to best project)
  jira open <key>              Open ticket in browser
  jira me                      Show your user info
  jira route <summary>         Show which project a task would go to
  jira todo                    Combined todo: Jira issues + Confluence tasks
  jira confluence pages [SPACE]      List recent Confluence pages
  jira confluence search <query>     Search Confluence (CQL)
  jira confluence tasks              Your incomplete Confluence inline tasks
  jira confluence view <page-id>     View a Confluence page
  jira sync                          Pull assigned Jira issues + Confluence tasks → beads
  jira start <key>                   Transition Jira → In Progress + beads in_progress
  jira done <key>                    Transition Jira → Done + close beads issue
"""

